# ========================================
# Configuração do Servidor SMTP (Relay)
# ========================================

# Servidor relay Google Workspace
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587

# Relay sem autenticação por usuário/senha (autorizado por IP)
SMTP_AUTH=false
SMTP_USER=
SMTP_PASS=

# TLS é necessário no smtp-relay.gmail.com porta 587
SMTP_SECURE=tls

# Remetente do e-mail
MAIL_FROM=naoresponder@facchini.com.br
MAIL_NAME=FacchiniLOG - Expedicao